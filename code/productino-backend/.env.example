NODE_ENV=development
PORT=8080

# Inside docker the host is the `postgres` service; from your host machine use localhost:5433
DATABASE_URL=postgresql://productino:secret@postgres:5432/productino

# Comma-separated list of origins allowed to call the API
ALLOWED_ORIGINS=http://dev.production.io,http://localhost:3000,http://127.0.0.1:3000

# --- Auth ---
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d
# Shared secret for the example MasterTokenGuard (X-Master-Token header)
MASTER_TOKEN=dev-master-token-change-me

# --- AI provider (for the briefing -> plan/questions/PRD features) ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-7
