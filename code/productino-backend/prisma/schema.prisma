generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStage {
  BRIEFING
  GAP_ANALYSIS
  AWAITING_CLIENT
  DEFINITION
  PLANNING
  PROPOSAL
}

enum SourceKind {
  BRIEFING
  TRANSCRIPT
  EMAIL
  ANSWERS
}

enum BeliefNodeType {
  REQUIREMENT
  ASSUMPTION
  RISK
  DECISION
}

enum BeliefStatus {
  STATED
  INFERRED
  ASSUMED
  CONFIRMED
  REJECTED
  CONTRADICTED
}

enum CoverageStatus {
  UNDERDEFINED
  THIN
  ADEQUATE
  SOLID
}

enum QuestionImpact {
  HIGH
  MEDIUM
  LOW
}

enum QuestionStatus {
  OPEN
  INCLUDED
  EXCLUDED
  ANSWERED
}

enum ConflictStatus {
  OPEN
  RESOLVED
}

enum DeliveryLevel {
  EPIC
  STORY
  TASK
}

model Account {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String?   @unique
  isSystem  Boolean   @default(false)
  bringYourOwnAi Boolean @default(false)
  users     User[]
  clients   Client[]
  projects  Project[]
  settings  Setting[]
  aiModels  AiModel[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("accounts")
}

model AiModel {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  label     String?
  provider  String
  model     String
  apiKey    String?  @db.Text
  baseUrl   String?
  options   Json     @default("{}")
  isActive  Boolean  @default(false)
  runCount   Int       @default(0)
  tokensIn   Int       @default(0)
  tokensOut  Int       @default(0)
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@map("ai_models")
}

model Client {
  id        Int       @id @default(autoincrement())
  accountId Int
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?   @db.Text
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([accountId, name])
  @@index([accountId])
  @@map("clients")
}

model User {
  id              Int          @id @default(autoincrement())
  email           String       @unique
  name            String?
  passwordHash    String?
  active          Boolean      @default(false)
  activationToken String?      @unique
  accountId       Int
  account         Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  permissions    Permission[] @relation("UserPermissions")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([accountId])
  @@map("users")
}

model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  description String?
  users       User[]   @relation("UserPermissions")
  createdAt   DateTime @default(now())

  @@map("permissions")
}

model Setting {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  key         String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, key])
  @@map("settings")
}

model Project {
  id          Int          @id @default(autoincrement())
  accountId   Int
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId    Int
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  stage        ProjectStage  @default(BRIEFING)
  rubric       Json?
  sources       Source[]
  beliefNodes   BeliefNode[]
  coverageAreas CoverageArea[]
  questions     Question[]
  rounds        ProjectRound[]
  conflicts     Conflict[]
  definitions   ProductDefinition[]
  deliveryItems DeliveryItem[]
  proposals     Proposal[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([accountId])
  @@index([clientId])
  @@map("projects")
}

model Source {
  id        Int        @id @default(autoincrement())
  projectId Int
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      SourceKind @default(BRIEFING)
  label     String?
  content   String     @db.Text
  round     Int        @default(1)
  createdAt DateTime   @default(now())

  @@index([projectId])
  @@map("sources")
}

model BeliefNode {
  id          Int            @id @default(autoincrement())
  projectId   Int
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodeType    BeliefNodeType @default(REQUIREMENT)
  kind        String
  name        String
  description String?        @db.Text
  status      BeliefStatus   @default(INFERRED)
  confidence  Float          @default(0)
  coverageKey String?
  provenance  Json           @default("[]")
  round       Int            @default(1)
  extra       Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@index([coverageKey])
  @@map("belief_nodes")
}

model CoverageArea {
  id               Int            @id @default(autoincrement())
  projectId        Int
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key              String
  name             String
  weight           String         @default("medium") // high | medium | low
  rollupConfidence Float          @default(0)
  status           CoverageStatus @default(UNDERDEFINED)
  round            Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
  @@map("coverage_areas")
}

model Question {
  id            Int            @id @default(autoincrement())
  projectId     Int
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coverageKey   String?
  text          String         @db.Text
  assumedAnswer String?        @db.Text
  impact        QuestionImpact @default(MEDIUM)
  status        QuestionStatus @default(OPEN)
  answerText    String?        @db.Text
  round         Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@map("questions")
}

model ProjectRound {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  index            Int
  rollupConfidence Float    @default(0)
  createdAt        DateTime @default(now())

  @@unique([projectId, index])
  @@index([projectId])
  @@map("project_rounds")
}

model Conflict {
  id        Int            @id @default(autoincrement())
  projectId Int
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  summary   String
  detail    String         @db.Text
  beliefA   String
  beliefB   String
  status    ConflictStatus @default(OPEN)
  round     Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([projectId])
  @@map("conflicts")
}

model Proposal {
  id            Int      @id @default(autoincrement())
  projectId     Int
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version       Int
  content       Json
  currency      String
  dayRate       Int
  totalLowCost  Int      @default(0)
  totalHighCost Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([projectId, version])
  @@index([projectId])
  @@map("proposals")
}

model DeliveryItem {
  id           Int            @id @default(autoincrement())
  projectId    Int
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId     Int?
  parent       DeliveryItem?  @relation("ItemChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children     DeliveryItem[] @relation("ItemChildren")
  level        DeliveryLevel
  title        String
  description  String?        @db.Text
  estimateLow  Int?
  estimateHigh Int?
  phase        String?
  orderIndex   Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([projectId])
  @@index([parentId])
  @@map("delivery_items")
}

model ProductDefinition {
  id                     Int      @id @default(autoincrement())
  projectId              Int
  project                Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version                Int
  content                Json
  confidenceAtGeneration Float    @default(0)
  gateOverride           Boolean  @default(false)
  overrideReason         String?
  createdAt              DateTime @default(now())

  @@unique([projectId, version])
  @@index([projectId])
  @@map("product_definitions")
}

model Prompt {
  id              Int                @id @default(autoincrement())
  key             String             @unique
  description     String?
  activeVersionId Int?
  versions        PromptVersion[]
  experiments     PromptExperiment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("prompts")
}

model PromptVersion {
  id        Int      @id @default(autoincrement())
  promptId  Int
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  content   String   @db.Text
  config    Json     @default("{}")
  checksum  String
  source    String   @default("file") // file | ui
  notes     String?
  createdAt DateTime @default(now())

  @@unique([promptId, version])
  @@map("prompt_versions")
}

model PromptExperiment {
  id        Int      @id @default(autoincrement())
  promptId  Int
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  status    String   @default("draft") // draft | running | done
  variants  Json     @default("[]") // [{ versionId, weight }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prompt_experiments")
}

model PromptRun {
  id           Int      @id @default(autoincrement())
  promptKey    String
  versionId    Int
  experimentId Int?
  subjectType  String?
  subjectId    Int?
  success      Boolean?
  latencyMs    Int?
  tokensIn     Int?
  tokensOut    Int?
  provider     String?
  model        String?
  score        Float?
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([promptKey])
  @@map("prompt_runs")
}
