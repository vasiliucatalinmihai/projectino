generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStage {
  BRIEFING
  GAP_ANALYSIS
  AWAITING_CLIENT
  DEFINITION
  PLANNING
  DELIVERY
}

// --- Belief Graph enums -----------------------------------------------------

// Where a piece of raw input came from. The first briefing is BRIEFING; later
// rounds add transcripts / emails / pasted client ANSWERS.
enum SourceKind {
  BRIEFING
  TRANSCRIPT
  EMAIL
  ANSWERS
}

// A belief node's role in the Understanding layer. REQUIREMENT covers the
// `kind` sub-types (feature/goal/rule/nfr/...); RISK/DECISION arrive in Phase 6.
enum BeliefNodeType {
  REQUIREMENT
  ASSUMPTION
  RISK
  DECISION
}

// How sure we are of a belief and where it stands. The core epistemic axis: a
// transcript's "we'd probably want…" is INFERRED, not silently CONFIRMED.
enum BeliefStatus {
  STATED
  INFERRED
  ASSUMED
  CONFIRMED
  REJECTED
  CONTRADICTED
}

// Coverage of a rubric category, derived from its nodes' confidence.
enum CoverageStatus {
  UNDERDEFINED
  THIN
  ADEQUATE
  SOLID
}

enum QuestionImpact {
  HIGH
  MEDIUM
  LOW
}

// A question's lifecycle: proposed (OPEN) → curated in/out (INCLUDED/EXCLUDED)
// → ANSWERED once the client replies.
enum QuestionStatus {
  OPEN
  INCLUDED
  EXCLUDED
  ANSWERED
}

// A tenant: a company using the app. Users, projects and settings belong to one.
// The system account (isSystem = true) hosts super admins who cross tenants.
model Account {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String?   @unique
  isSystem  Boolean   @default(false)
  // When true, processing uses this account's own AI models/credentials;
  // when false, the platform's default model is used. Super-admin controlled.
  bringYourOwnAi Boolean @default(false)
  users     User[]
  clients   Client[]
  projects  Project[]
  settings  Setting[]
  aiModels  AiModel[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("accounts")
}

// An LLM configuration an account can use when "bring your own AI" is enabled.
// Exactly one per account is active at a time (the one used for processing).
model AiModel {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  label     String?
  provider  String   // e.g. anthropic, openai, google, azure-openai
  model     String   // e.g. claude-opus-4-7, gpt-4o
  apiKey    String?  @db.Text
  baseUrl   String?  // optional custom endpoint / proxy
  // Provider-specific knobs passed through on every call (e.g. temperature,
  // Anthropic output_config/thinking, OpenAI response_format). Same shape for
  // tenant models and the system default.
  options   Json     @default("{}")
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@map("ai_models")
}

// A client (the agency's customer) belonging to one account. Every project is
// scoped to a client; the client carries the contact details for that engagement.
model Client {
  id        Int       @id @default(autoincrement())
  accountId Int
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?   @db.Text
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([accountId, name])
  @@index([accountId])
  @@map("clients")
}

model User {
  id              Int          @id @default(autoincrement())
  email           String       @unique
  name            String?
  // Null until the user activates their account by setting a password.
  passwordHash    String?
  // Inactive users cannot log in. New users start inactive and become active
  // once they consume their activationToken.
  active          Boolean      @default(false)
  // Opaque one-shot token used to set/reset a password (no email flow).
  // Cleared once consumed.
  activationToken String?      @unique
  accountId       Int
  account         Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  permissions    Permission[] @relation("UserPermissions")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([accountId])
  @@map("users")
}

// A permission is a row, not a hard-coded enum, so the set can grow without a
// schema change. The `key` matches the PermissionKey enum used in code/guards.
model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  description String?
  users       User[]   @relation("UserPermissions")
  createdAt   DateTime @default(now())

  @@map("permissions")
}

// Simple key/value settings store for app-wide configuration that can be
// edited at runtime and read anywhere in the project.
model Setting {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  key         String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, key])
  @@map("settings")
}

// Example domain model. Demonstrates the repository + active-record pattern.
// A Project is one client engagement moving through the discovery pipeline.
model Project {
  id          Int          @id @default(autoincrement())
  accountId   Int
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId    Int
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  stage        ProjectStage  @default(BRIEFING)
  // Belief Graph (the project's source of truth). Raw inputs live in `sources`;
  // `beliefNodes` + `coverageAreas` + `questions` are the Understanding layer;
  // `rounds` snapshot convergence so deltas can be shown between question rounds.
  sources       Source[]
  beliefNodes   BeliefNode[]
  coverageAreas CoverageArea[]
  questions     Question[]
  rounds        ProjectRound[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([accountId])
  @@index([clientId])
  @@map("projects")
}

// --- Belief Graph -----------------------------------------------------------

// EVIDENCE layer: immutable raw input. The initial briefing is the first
// Source (round 1); later client answers/transcripts are added as new Sources.
model Source {
  id        Int        @id @default(autoincrement())
  projectId Int
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kind      SourceKind @default(BRIEFING)
  label     String?
  content   String     @db.Text
  round     Int        @default(1)
  createdAt DateTime   @default(now())

  @@index([projectId])
  @@map("sources")
}

// UNDERSTANDING layer: one polymorphic table for every belief, wearing the
// epistemic envelope (status + confidence + provenance + round). `kind`
// sub-types a REQUIREMENT (feature|goal|rule|nfr|integration|data|platform|
// stakeholder); `extra` holds type-specific fields (e.g. risk severity).
// `provenance` is [{ sourceId, span:[start,end], quote }] — why we believe it.
model BeliefNode {
  id          Int            @id @default(autoincrement())
  projectId   Int
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  nodeType    BeliefNodeType @default(REQUIREMENT)
  kind        String
  name        String
  description String?        @db.Text
  status      BeliefStatus   @default(INFERRED)
  confidence  Float          @default(0)
  coverageKey String?
  provenance  Json           @default("[]")
  round       Int            @default(1)
  extra       Json           @default("{}")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@index([coverageKey])
  @@map("belief_nodes")
}

// The convergence engine: one rubric category, with a confidence rolled up from
// its belief nodes. The weighted project rollup is the "defined enough?" gate.
model CoverageArea {
  id               Int            @id @default(autoincrement())
  projectId        Int
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key              String
  name             String
  weight           String         @default("medium") // high | medium | low
  rollupConfidence Float          @default(0)
  status           CoverageStatus @default(UNDERDEFINED)
  round            Int            @default(1)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([projectId, key])
  @@index([projectId])
  @@map("coverage_areas")
}

// A clarifying question with its proposed default answer. Curated in/out, then
// ANSWERED when the client replies (answer folded back into a new round).
model Question {
  id            Int            @id @default(autoincrement())
  projectId     Int
  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coverageKey   String?
  text          String         @db.Text
  assumedAnswer String?        @db.Text
  impact        QuestionImpact @default(MEDIUM)
  status        QuestionStatus @default(OPEN)
  answerText    String?        @db.Text
  round         Int            @default(1)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@map("questions")
}

// Snapshot of the weighted project rollup at the end of a round, so the UI can
// show the convergence delta ("Compliance 20% → 75%") between rounds.
model ProjectRound {
  id               Int      @id @default(autoincrement())
  projectId        Int
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  index            Int
  rollupConfidence Float    @default(0)
  createdAt        DateTime @default(now())

  @@unique([projectId, index])
  @@index([projectId])
  @@map("project_rounds")
}

// --- Prompt manager ---------------------------------------------------------

// One row per use case (keyed by a stable PromptKey). `activeVersionId` is the
// pinned "live" version resolved at runtime.
model Prompt {
  id              Int                @id @default(autoincrement())
  key             String             @unique
  description     String?
  activeVersionId Int?
  versions        PromptVersion[]
  experiments     PromptExperiment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("prompts")
}

// Immutable snapshot of a prompt's text + model config, created whenever the
// source file's checksum changes.
model PromptVersion {
  id        Int      @id @default(autoincrement())
  promptId  Int
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  content   String   @db.Text
  config    Json     @default("{}")
  checksum  String
  source    String   @default("file") // file | ui
  notes     String?
  createdAt DateTime @default(now())

  @@unique([promptId, version])
  @@map("prompt_versions")
}

// Phase 3 (A/B). Present in the schema but not yet used by any code.
model PromptExperiment {
  id        Int      @id @default(autoincrement())
  promptId  Int
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  status    String   @default("draft") // draft | running | done
  variants  Json     @default("[]") // [{ versionId, weight }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prompt_experiments")
}

// Phase 2 (outcome log). Present in the schema but not yet used by any code.
model PromptRun {
  id           Int      @id @default(autoincrement())
  promptKey    String
  versionId    Int
  experimentId Int?
  subjectType  String?
  subjectId    Int?
  success      Boolean?
  latencyMs    Int?
  tokensIn     Int?
  tokensOut    Int?
  // The provider/model that actually served the run (account-configured, not
  // the prompt version). Null when the call failed before a model responded.
  provider     String?
  model        String?
  score        Float?
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([promptKey])
  @@map("prompt_runs")
}
