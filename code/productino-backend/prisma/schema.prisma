generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStage {
  BRIEFING
  GAP_ANALYSIS
  AWAITING_CLIENT
  DEFINITION
  PLANNING
  DELIVERY
}

// A tenant: a company using the app. Users, projects and settings belong to one.
// The system account (isSystem = true) hosts super admins who cross tenants.
model Account {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String?   @unique
  isSystem  Boolean   @default(false)
  // When true, processing uses this account's own AI models/credentials;
  // when false, the platform's default model is used. Super-admin controlled.
  bringYourOwnAi Boolean @default(false)
  users     User[]
  clients   Client[]
  projects  Project[]
  settings  Setting[]
  aiModels  AiModel[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("accounts")
}

// An LLM configuration an account can use when "bring your own AI" is enabled.
// Exactly one per account is active at a time (the one used for processing).
model AiModel {
  id        Int      @id @default(autoincrement())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  label     String?
  provider  String   // e.g. anthropic, openai, google, azure-openai
  model     String   // e.g. claude-opus-4-7, gpt-4o
  apiKey    String?  @db.Text
  baseUrl   String?  // optional custom endpoint / proxy
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
  @@map("ai_models")
}

// A client (the agency's customer) belonging to one account. Every project is
// scoped to a client; the client carries the contact details for that engagement.
model Client {
  id        Int       @id @default(autoincrement())
  accountId Int
  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  address   String?
  notes     String?   @db.Text
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([accountId, name])
  @@index([accountId])
  @@map("clients")
}

model User {
  id           Int          @id @default(autoincrement())
  email        String       @unique
  name         String?
  passwordHash String
  accountId    Int
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  permissions  Permission[] @relation("UserPermissions")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([accountId])
  @@map("users")
}

// A permission is a row, not a hard-coded enum, so the set can grow without a
// schema change. The `key` matches the PermissionKey enum used in code/guards.
model Permission {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  description String?
  users       User[]   @relation("UserPermissions")
  createdAt   DateTime @default(now())

  @@map("permissions")
}

// Simple key/value settings store for app-wide configuration that can be
// edited at runtime and read anywhere in the project.
model Setting {
  id          Int      @id @default(autoincrement())
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  key         String
  value       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, key])
  @@map("settings")
}

// Example domain model. Demonstrates the repository + active-record pattern.
// A Project is one client engagement moving through the discovery pipeline.
model Project {
  id          Int          @id @default(autoincrement())
  accountId   Int
  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  clientId    Int
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  briefing    String?      @db.Text
  stage       ProjectStage @default(BRIEFING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([accountId])
  @@index([clientId])
  @@map("projects")
}

// --- Prompt manager ---------------------------------------------------------

// One row per use case (keyed by a stable PromptKey). `activeVersionId` is the
// pinned "live" version resolved at runtime.
model Prompt {
  id              Int                @id @default(autoincrement())
  key             String             @unique
  description     String?
  activeVersionId Int?
  versions        PromptVersion[]
  experiments     PromptExperiment[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@map("prompts")
}

// Immutable snapshot of a prompt's text + model config, created whenever the
// source file's checksum changes.
model PromptVersion {
  id        Int      @id @default(autoincrement())
  promptId  Int
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  version   Int
  content   String   @db.Text
  config    Json     @default("{}")
  checksum  String
  source    String   @default("file") // file | ui
  notes     String?
  createdAt DateTime @default(now())

  @@unique([promptId, version])
  @@map("prompt_versions")
}

// Phase 3 (A/B). Present in the schema but not yet used by any code.
model PromptExperiment {
  id        Int      @id @default(autoincrement())
  promptId  Int
  prompt    Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  status    String   @default("draft") // draft | running | done
  variants  Json     @default("[]") // [{ versionId, weight }]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("prompt_experiments")
}

// Phase 2 (outcome log). Present in the schema but not yet used by any code.
model PromptRun {
  id           Int      @id @default(autoincrement())
  promptKey    String
  versionId    Int
  experimentId Int?
  subjectType  String?
  subjectId    Int?
  success      Boolean?
  latencyMs    Int?
  tokensIn     Int?
  tokensOut    Int?
  score        Float?
  meta         Json?
  createdAt    DateTime @default(now())

  @@index([promptKey])
  @@map("prompt_runs")
}
